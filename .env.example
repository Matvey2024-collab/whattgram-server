# Required - MongoDB Atlas connection string
# Get one free at https://www.mongodb.com/cloud/atlas
MONGODB_URI=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/whattgram?retryWrites=true&w=majority

# Required - Gmail App Password for sending verification codes
EMAIL_USER=whatttgram@gmail.com
EMAIL_PASS=your-app-password

# Required - Admin password for the @WhattGram system channel
SYSTEM_USER_PASSWORD=admin123

# Optional - secret for broadcast API
SYSTEM_SECRET=your_secret_key

# Optional - allowed IPs for broadcast API
ALLOWED_BROADCAST_IPS=127.0.0.1
